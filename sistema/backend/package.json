{
  "name": "guardiao-da-cozinha-backend",
  "version": "1.0.0",
  "description": "API REST do Guardião da Cozinha",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/services/**/*.js",
      "src/utils/**/*.js"
    ],
    "coverageReporters": ["text", "text-summary", "lcov"],
    "coverageThreshold": {
      "global": {
        "lines":      80,
        "functions":  80,
        "statements": 80,
        "branches":   70
      }
    }
  }
}
